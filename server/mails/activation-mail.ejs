<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scoob Invoice Activation Email</title>
    <style>
      /* Base Styles */
      body {
        margin: 0;
        padding: 0;
        font-family: "Segoe UI", Arial, Helvetica, sans-serif;
        background-color: #f4f6f8;
        color: #333;
      }

      a {
        text-decoration: none;
      }

      .container {
        max-width: 600px;
        margin: 40px auto;
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
        overflow: hidden;
      }

      /* Header */
      .header {
        background: linear-gradient(135deg, #180971, #384193);
        color: #ffffff;
        text-align: center;
        padding: 32px 20px;
      }

      .header h1 {
        margin: 0;
        font-size: 26px;
        letter-spacing: 0.5px;
      }

      /* Body */
      .body {
        padding: 32px 24px;
      }

      .body p {
        font-size: 16px;
        line-height: 1.6;
        margin: 16px 0;
      }

      /* Button */
      .button {
        display: inline-block;
        background-color: #180971;
        color: #ffffff;
        font-weight: 600;
        padding: 14px 28px;
        border-radius: 6px;
        margin-top: 24px;
        transition: background-color 0.2s ease;
      }

      .button:hover {
        background-color: #384193;
      }

      /* Footer */
      .footer {
        background-color: #f9fafb;
        text-align: center;
        font-size: 14px;
        padding: 24px 16px;
        color: #6b7280;
      }

      .footer a {
        color: #180971;
        font-weight: 500;
      }

      /* Responsive */
      @media screen and (max-width: 600px) {
        .body {
          padding: 24px 16px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <!-- Header -->
      <div class="header">
        <h1>Welcome to Scoob Invoice</h1>
      </div>

      <!-- Body -->
      <div class="body">
        <p>Hello <strong><%= user.name %></strong>,</p>
        <p>
          Thank you for registering with the
          <strong>Scoob Invoice</strong>. Please activate your account by
          clicking the button below within the next 5 minutes:
        </p>

        <p style="text-align: center">
          <a href="<%= activationUrl %>" class="button">Activate Account</a>
        </p>

        <p>
          If you did not register for a Scoob Invoice account, please ignore
          this email.
        </p>
      </div>

      <!-- Footer -->
      <div class="footer">
        <p>
          Need help? Contact our support team at
          <a href="mailto:support@scoob.com">support@scoob.com</a>
        </p>
        <p>
          © <%= new Date().getFullYear() %> Scoob Invoice. All rights reserved.
        </p>
      </div>
    </div>
  </body>
</html>
